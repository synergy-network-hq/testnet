    {
      "id": 7,
      "type": "timeseries",
      "title": "Block Interval / Finalization Proxy (seconds, p50 / p95 / p99)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.50, synergy_chain_latest_block_interval_seconds{job=\"synergy-validators\"}[5m])",
          "legendFormat": "{{instance_label}} p50"
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.95, synergy_chain_latest_block_interval_seconds{job=\"synergy-validators\"}[5m])",
          "legendFormat": "{{instance_label}} p95"
        },
        {
          "refId": "C",
          "expr": "quantile_over_time(0.99, synergy_chain_latest_block_interval_seconds{job=\"synergy-validators\"}[5m])",
          "legendFormat": "{{instance_label}} p99"
        },
        {
          "refId": "D",
          "expr": "synergy_consensus_config{job=\"synergy-validators\",setting=\"block_time_secs\"}",
          "legendFormat": "{{instance_label}} target"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
