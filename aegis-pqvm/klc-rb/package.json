{
  "name": "aegis-klc-rb",
  "version": "0.1.0",
  "description": "Aegis Key Lifecycle Manager and Quantum Randomness Beacon - WASM build",
  "main": "pkg/aegis_klc_rb.js",
  "types": "pkg/aegis_klc_rb.d.ts",
  "type": "module",
  "files": [
    "pkg/",
    "pkg-nodejs/",
    "pkg-bundler/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "./build-wasm.sh",
    "build:web": "wasm-pack build --target web --out-dir pkg --features wasm,mlkem,mldsa,serde",
    "build:node": "wasm-pack build --target nodejs --out-dir pkg-nodejs --features wasm,mlkem,mldsa,serde",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler --features wasm,mlkem,mldsa,serde",
    "test": "cargo test --features wasm,mlkem,mldsa,serde",
    "test:wasm": "wasm-pack test --headless --firefox"
  },
  "keywords": [
    "post-quantum",
    "cryptography",
    "key-lifecycle",
    "randomness-beacon",
    "wasm",
    "webassembly"
  ],
  "author": "Aegis PQC Team",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/synergy-network-hq/aegis.git"
  },
  "devDependencies": {
    "wasm-pack": "^0.12.1"
  }
}
