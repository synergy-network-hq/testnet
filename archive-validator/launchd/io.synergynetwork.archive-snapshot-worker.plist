<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.synergynetwork.archive-snapshot-worker</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/synergy/bin/synergy-archive</string>
    <string>create-snapshot</string>
    <string>--latest-eligible</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>SYNERGY_ARCHIVE_CONFIG</key>
    <string>/Library/Application Support/Synergy/archive-validator/config/archive-validator.toml</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>60</integer>
  <key>StandardOutPath</key>
  <string>/Library/Logs/Synergy/archive-validator/snapshot-worker.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Logs/Synergy/archive-validator/snapshot-worker.err.log</string>
</dict>
</plist>
