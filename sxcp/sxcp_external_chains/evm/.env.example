SEPOLIA_RPC_URL=https://sepolia.example-rpc.net
AMOY_RPC_URL=https://polygon-amoy.example-rpc.net
DEPLOYER_PRIVATE_KEY=0xyourdeployerprivatekey

# Comma-separated relayer addresses used to initialize epoch 1.
INITIAL_RELAYER_ADDRESSES=0x1111111111111111111111111111111111111111,0x2222222222222222222222222222222222222222

# Threshold for epoch 1. Must be <= number of initial relayers.
INITIAL_THRESHOLD=2

# Finality requirements by source chain.
SEPOLIA_FINALITY_CONFIRMATIONS=12
AMOY_FINALITY_CONFIRMATIONS=64

# Optional comma-separated private keys for demo attestation signing.
RELAYER_PRIVATE_KEYS=0xkey1,0xkey2
