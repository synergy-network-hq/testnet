# Copy this file to testbeta/lean15/hosts.env and set real values.
# Fast path:
#   ./scripts/testbeta/generate-monitor-hosts-env.sh
# This generates a fully wired hosts.env that lets the Node Monitor app install,
# bootstrap, manage, and monitor nodes via scripts/testbeta/remote-node-orchestrator.sh.
#
# Closed-testnet-beta rules:
# - MACHINE_XX_HOST should be VPN-reachable/internal DNS only.
# - MACHINE_XX_VPN_IP is the authoritative P2P/RPC bind identity.
# - Never expose 10.50.0.0/24 node ports publicly.

MACHINE_01_HOST=n01.testbeta.internal
MACHINE_02_HOST=n02.testbeta.internal
MACHINE_03_HOST=n03.testbeta.internal
MACHINE_04_HOST=n04.testbeta.internal
MACHINE_05_HOST=n05.testbeta.internal
MACHINE_06_HOST=n06.testbeta.internal
MACHINE_07_HOST=n07.testbeta.internal
MACHINE_08_HOST=n08.testbeta.internal
MACHINE_09_HOST=n09.testbeta.internal
MACHINE_10_HOST=n10.testbeta.internal
MACHINE_11_HOST=n11.testbeta.internal
MACHINE_12_HOST=n12.testbeta.internal
MACHINE_13_HOST=n13.testbeta.internal
MACHINE_14_HOST=n14.testbeta.internal
MACHINE_15_HOST=n15.testbeta.internal

MACHINE_01_VPN_IP=10.50.0.1
MACHINE_02_VPN_IP=10.50.0.2
MACHINE_03_VPN_IP=10.50.0.3
MACHINE_04_VPN_IP=10.50.0.4
MACHINE_05_VPN_IP=10.50.0.5
MACHINE_06_VPN_IP=10.50.0.6
MACHINE_07_VPN_IP=10.50.0.7
MACHINE_08_VPN_IP=10.50.0.8
MACHINE_09_VPN_IP=10.50.0.9
MACHINE_10_VPN_IP=10.50.0.10
MACHINE_11_VPN_IP=10.50.0.11
MACHINE_12_VPN_IP=10.50.0.12
MACHINE_13_VPN_IP=10.50.0.13
MACHINE_14_VPN_IP=10.50.0.14
MACHINE_15_VPN_IP=10.50.0.15

# Optional: remote control commands used by the Testnet Beta Infrastructure monitor.
# Add these for each machine you want to control from the monitor UI.
# Recommended approach is SSH from the monitor host into each node host.
# Better approach: use scripts/testbeta/remote-node-orchestrator.sh and wire commands
# once with scripts/testbeta/generate-monitor-hosts-env.sh.
# Example keys:
# MACHINE_01_START_CMD=ssh -o BatchMode=yes ops@node01.example.com "cd /opt/synergy/machine-01 && ./install_and_start.sh"
# MACHINE_01_STOP_CMD=ssh -o BatchMode=yes ops@node01.example.com "cd /opt/synergy/machine-01 && ./nodectl.sh stop"
# MACHINE_01_RESET_CMD=ssh -o BatchMode=yes ops@node01.example.com "rm -rf /opt/synergy/machine-01/data/chain /opt/synergy/machine-01/data/logs && mkdir -p /opt/synergy/machine-01/data/chain /opt/synergy/machine-01/data/logs"
# MACHINE_01_RESTART_CMD=ssh -o BatchMode=yes ops@node01.example.com "cd /opt/synergy/machine-01 && ./nodectl.sh restart"
# MACHINE_01_STATUS_CMD=ssh -o BatchMode=yes ops@node01.example.com "cd /opt/synergy/machine-01 && ./nodectl.sh status"
# MACHINE_01_SETUP_CMD=ssh -o BatchMode=yes ops@node01.example.com "cd /opt/synergy/machine-01 && ./install_and_start.sh --setup-only"
# MACHINE_01_EXPORT_LOGS_CMD=ssh -o BatchMode=yes ops@node01.example.com "tar -C /opt/synergy/machine-01 -czf /tmp/machine-01-logs.tgz data/logs && ls -lh /tmp/machine-01-logs.tgz"
# MACHINE_01_VIEW_CHAIN_DATA_CMD=ssh -o BatchMode=yes ops@node01.example.com "du -sh /opt/synergy/machine-01/data/chain && ls -lah /opt/synergy/machine-01/data/chain | head -40"
# MACHINE_01_EXPORT_CHAIN_DATA_CMD=ssh -o BatchMode=yes ops@node01.example.com "tar -C /opt/synergy/machine-01 -czf /tmp/machine-01-chain.tgz data/chain && ls -lh /tmp/machine-01-chain.tgz"
# MACHINE_01_ACTION_REPAIR_INDEX_CMD=ssh -o BatchMode=yes ops@node01.example.com "cd /opt/synergy/machine-01 && ./nodectl.sh repair-index"

# Atlas / explorer integration for monitor deep links.
# ATLAS_BASE_URL is preferred, EXPLORER_URL is accepted as fallback.
ATLAS_BASE_URL=https://testbeta-explorer.synergy-network.io
# EXPLORER_URL=https://testbeta-explorer.synergy-network.io
